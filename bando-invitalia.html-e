        body { background-color: var(--bg-light); color: var(--text-dark); line-height: 1.6; font-size: 1.1rem; }
        header { background-color: var(--primary-blue); color: white; padding: 1rem; text-align: left; }
        header a { color: white; text-decoration: none; font-weight: 800; font-size: 1.2rem; }
        .container { max-width: 800px; margin: 2rem auto; padding: 2rem; background: white; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        h1 { font-size: 2.2rem; font-weight: 800; color: var(--primary-blue); margin-bottom: 1rem; line-height: 1.2; letter-spacing: -1px; }
        h2 { font-size: 1.6rem; font-weight: 800; color: var(--primary-blue); margin-top: 2.5rem; margin-bottom: 1rem; }
        p, ul { margin-bottom: 1.5rem; }
        ul { margin-left: 1.5rem; }
        .bureaucracy-box { background: #FFFBEB; border-left: 5px solid #F59E0B; padding: 1.5rem; margin: 2rem 0; border-radius: 0 8px 8px 0; }
        .bureaucracy-box h3 { color: #B45309; margin-bottom: 0.8rem; font-size: 1.3rem; }
        .step-list { counter-reset: steps; list-style: none; margin: 2rem 0; padding: 0; margin-left: 0; }
        .step-list li { position: relative; padding-left: 3.5rem; margin-bottom: 2rem; }
        .step-list li::before { content: counter(steps); counter-increment: steps; position: absolute; left: 0; top: -4px; background: var(--primary-blue); color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem; }
        .ads-placeholder { width: 100%; min-height: 250px;  display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.9rem; margin: 2.5rem 0; }
